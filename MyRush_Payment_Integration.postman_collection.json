{
	"info": {
		"_postman_id": "a1b2c3d4-e5f6-7g8h-9i0j-k1l2m3n4o5p6",
		"name": "MyRush Payment & Vriksha Integration",
		"description": "Postman collection for testing MyRush payment APIs and Razorpay Webhook forwarding to Vriksha service.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Authentication",
			"item": [
				{
					"name": "Send OTP",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"phone_number\": \"1234567890\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/user/auth/send-otp",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"user",
								"auth",
								"send-otp"
							]
						}
					},
					"response": []
				},
				{
					"name": "Verify OTP",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.access_token) {",
									"    pm.environment.set(\"accessToken\", jsonData.access_token);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"phone_number\": \"1234567890\",\n    \"otp_code\": \"12345\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/user/auth/verify-otp",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"user",
								"auth",
								"verify-otp"
							]
						}
					},
					"response": []
				}
			]
		},
		{
			"name": "2. Payments",
			"item": [
				{
					"name": "Create Order",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.id) {",
									"    pm.environment.set(\"lastOrderId\", jsonData.id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{accessToken}}",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"branch_id\": \"f4de87f7-dd91-4a74-beeb-8eeb9fb3f564\",\n    \"court_id\": \"231a604e-9a33-4984-820f-3d32df1f23fe\",\n    \"booking_date\": \"2026-04-15\",\n    \"start_time\": \"10:00\",\n    \"duration_minutes\": 30,\n    \"time_slots\": [{\"time\": \"10:00\"}],\n    \"number_of_players\": 1,\n    \"slice_mask\": 0\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/user/payments/create-order",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"user",
								"payments",
								"create-order"
							]
						}
					},
					"response": []
				},
				{
					"name": "Simulate Webhook (Triggers Vriksha)",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"// This script calculates the Razorpay Signature automatically",
									"var secret = pm.environment.get(\"razorpayWebhookSecret\");",
									"var body = pm.request.body.raw;",
									"if (secret && body) {",
									"    var signature = CryptoJS.HmacSHA256(body, secret).toString();",
									"    pm.request.headers.add({key: 'x-razorpay-signature', value: signature });",
									"    console.log(\"Generated Signature: \" + signature);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"event\": \"payment.captured\",\n  \"payload\": {\n    \"payment\": {\n      \"entity\": {\n        \"id\": \"pay_TEST_MOCK_123\",\n        \"amount\": 50000,\n        \"order_id\": \"{{lastOrderId}}\",\n        \"status\": \"captured\",\n        \"notes\": {\n           \"item_type\": \"PHONE\"\n        }\n      }\n    }\n  }\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/user/payments/webhook",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"user",
								"payments",
								"webhook"
							]
						},
						"description": "Simulates a Razorpay 'payment.captured' event. This triggers the Vriksha service forwarding logic in the backend."
					},
					"response": []
				}
			]
		}
	],
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					""
				]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"exec": [
					""
				]
			}
		}
	],
	"variable": [
		{
			"key": "baseUrl",
			"value": "https://api-staging.myrush.in/api",
			"type": "string"
		},
		{
			"key": "razorpayWebhookSecret",
			"value": "URNN4B_5nxFePEF",
			"type": "string"
		}
	]
}
