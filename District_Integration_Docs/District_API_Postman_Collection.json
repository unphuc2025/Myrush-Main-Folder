					"name": "Cancel Booking",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "formdata",
							"formdata": [
								{
									"key": "id",
									"value": "{{partner_id}}",
									"type": "text"
								},
								{
									"key": "apiKey",
									"value": "{{api_key}}",
									"type": "text"
								},
								{
									"key": "facilityName",
									"value": "Rush Arena",
									"type": "text"
								},
								{
									"key": "bookingID",
									"value": "DIST-SAMPLE123",
									"type": "text"
								}
							]
						},
						"url": {
							"raw": "{{base_url}}/api/cancelBooking/",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"cancelBooking",
								""
							]
						},
						"description": "Cancel a booking. Accepts either the Batch ID (e.g., DIST-ABCD123) or an individual slot level ID."
